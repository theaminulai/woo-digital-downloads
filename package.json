{
    "name": "digitally",
    "version": "1.0.0",
    "description": "Build tooling for Digitally for WooCommerce admin dashboard",
    "author": "Digitally",
    "license": "GPL-3.0-or-later",
    "private": true,
    "scripts": {
        "build":           "wp-scripts build",
        "start":           "wp-scripts start",
        "format":          "wp-scripts format ./src",
        "lint":            "npm run lint:js && npm run lint:css",
        "lint:js":         "wp-scripts lint-js",
        "lint:css":        "wp-scripts lint-style",
        "lint:fix":        "wp-scripts lint-js --fix && wp-scripts lint-style --fix",
        "lint:pkg-json":   "wp-scripts lint-pkg-json",
        "packages-update": "wp-scripts packages-update",
        "plugin-zip":      "wp-scripts plugin-zip",
        "make-pot":        "wp i18n make-pot . languages/digitally.pot --domain=digitally --exclude=node_modules,vendor,tests"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.23.0",
        "@actions/core": "^1.10.0",
        "npm-check-updates": "^16.14.20",
        "simple-git": "^3.27.0",
		"tailwindcss": "4.1.12",
        "webpack-remove-empty-scripts": "^1.1.1"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "react-router-dom": "^7.13.0",
		"lucide-react": "0.487.0",
		"react-router": "7.13.0",
		"recharts": "2.15.2",
		"sonner": "2.0.3",
		"tailwind-merge": "3.2.0",
		"tw-animate-css": "1.3.8"
    }
}
