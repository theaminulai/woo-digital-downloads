{
    "name": "woo-digital-downloads",
    "version": "1.0.0",
    "description": "Build tooling for Woo Digital Downloads admin dashboard",
    "author": "Digital Downloads",
    "license": "GPL-2.0-or-later",
    "private": true,
    "scripts": {
        "build":           "wp-scripts build",
        "start":           "wp-scripts start",
        "format":          "wp-scripts format ./src",
        "lint":            "npm run lint:js && npm run lint:css",
        "lint:js":         "wp-scripts lint-js",
        "lint:css":        "wp-scripts lint-style",
        "lint:fix":        "wp-scripts lint-js --fix && wp-scripts lint-style --fix",
        "lint:pkg-json":   "wp-scripts lint-pkg-json",
        "packages-update": "wp-scripts packages-update",
        "plugin-zip":      "wp-scripts plugin-zip",
        "make-pot":        "wp i18n make-pot . languages/woo-digital-downloads.pot --domain=woo-digital-downloads --exclude=node_modules,vendor,tests"
    },
    "devDependencies": {
        "@wordpress/scripts": "^30.23.0",
        "@actions/core": "^1.10.0",
        "npm-check-updates": "^16.14.20",
        "simple-git": "^3.27.0",
        "webpack-remove-empty-scripts": "^1.1.1"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "lucide-react": "^0.563.0",
        "react-router-dom": "^7.13.0",
        "recharts": "^2.15.3"
    }
}